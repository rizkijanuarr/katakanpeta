									"type": "string"
								}
							]
						},
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{BASE_URL}}/api/v1/admin/dashboard",
							"host": ["{{BASE_URL}}"],
							"path": ["api", "v1", "admin", "dashboard"]
