		}
	],
	"variable": [
		{
			"key": "BASE_URL",
			"value": "http://localhost:3000",
			"type": "string"
		},
		{
			"key": "TOKEN",
			"value": "",
			"type": "string"
		},
		{
			"key": "USER_EMAIL",
			"value": "user@gmail.com",
			"type": "string"
		},
		{
			"key": "USER_PASSWORD",
			"value": "password123",
			"type": "string"
		},
		{
			"key": "USER_ID",
			"value": "",
